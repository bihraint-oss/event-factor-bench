    "max_staleness_seconds": 120,
    "baseline": "raw_yes_reference_probability",
    "primary_method": "unweighted_nonincreasing_pav_projection",
    "comparators": [
      "event_balanced_platt",
      "event_balanced_beta",
      "beta_then_nonincreasing_pav"
    ],
    "calibration_training_split": "development",
    "calibration_epsilon": 1e-06,
    "calibration_l2": 0.001,
    "calibration_tolerance": 1e-09,
    "calibration_max_iterations": 100,
    "metric_log_loss_epsilon": 1e-06
