  "inference": {
    "statistical_unit": "event",
    "block": "UTC calendar day",
    "bootstrap": "paired hierarchical block/event percentile bootstrap",
    "confidence": 0.95,
    "resamples": 10000,
    "seed": 260715
  },
  "claim_gate": {
    "minimum_holdout_events": 500,
    "minimum_holdout_utc_days": 14,
    "minimum_event_coverage": 0.95,
    "minimum_contract_coverage": 0.95,
    "minimum_relative_brier_improvement": 0.001,
    "require_brier_ci_lower_above_zero": true,
    "maximum_event_macro_log_loss_regression": 0.001,
    "require_nonnegative_asset_subgroups": true
